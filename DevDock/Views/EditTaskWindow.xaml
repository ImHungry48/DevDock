<Window x:Class="DevDock.Views.EditTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Task"
        Width="430"
        Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="PopupTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#FF2E2E2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#FF2E2E2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#FF3A4A63"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF3A4A63"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PopupComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#FF2E2E2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6"/>
        </Style>

        <Style x:Key="PopupDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Background" Value="#FF2E2E2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF444444"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="PopupButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF3A4A63"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PopupButtonStyle}">
            <Setter Property="Background" Value="#FF6B3A3A"/>
        </Style>

        <Style x:Key="FlatIconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="PopupListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="#FF252525"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6"/>
        </Style>

        <Style x:Key="PopupCalendarStyle" TargetType="Calendar">
            <Setter Property="Background" Value="#FF2E2E2E"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="PopupDatePickerTextBoxStyle" TargetType="DatePickerTextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF2E2E2E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6"/>
        </Style>
    </Window.Resources>

    <Border Background="#FF1E1E1E"
            BorderBrush="#FF3A3A3A"
            BorderThickness="1"
            CornerRadius="18"
            Padding="16">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,12" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Edit Task"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Content="✕"
                        Style="{StaticResource FlatIconButtonStyle}"
                        Click="CancelButton_Click"/>
            </Grid>

            <!-- Title + Description -->
            <StackPanel Grid.Row="1">
                <TextBlock Text="Title" Foreground="#FFCCCCCC" Margin="0,0,0,4"/>
                <TextBox x:Name="TitleTextBox"
                         Text="{Binding Title}"
                         Style="{StaticResource PopupTextBoxStyle}"/>

                <TextBlock Text="Description" Foreground="#FFCCCCCC" Margin="0,0,0,4"/>
                <TextBox x:Name="DescriptionTextBox"
                         Text="{Binding Description}"
                         Style="{StaticResource PopupTextBoxStyle}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="80"
                         VerticalScrollBarVisibility="Auto"/>
            </StackPanel>

            <!-- Metadata -->
            <WrapPanel Grid.Row="2" Margin="0,0,0,10">
                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="Due Date" Foreground="#FFCCCCCC" Margin="0,0,0,4"/>
                    <DatePicker SelectedDate="{Binding DueDate}"
                                Width="120"
                                Style="{StaticResource PopupDatePickerStyle}"
                                Foreground="White"
                                Background="#FF2E2E2E"
                                CalendarStyle="{StaticResource PopupCalendarStyle}">
                        <DatePicker.Resources>
                            <Style TargetType="DatePickerTextBox" BasedOn="{StaticResource PopupDatePickerTextBoxStyle}"/>
                        </DatePicker.Resources>
                    </DatePicker>
                </StackPanel>

                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="Priority" Foreground="#FFCCCCCC" Margin="0,0,0,4"/>
                    <ComboBox x:Name="PriorityComboBox"
                                  Width="100"
                                  Style="{StaticResource PopupComboBoxStyle}"
                                  Foreground="White"
                                  Background="#FF2E2E2E"
                                  IsEditable="True"
                                  IsReadOnly="True"
                                  TextSearch.TextPath="."
                                  />
                </StackPanel>

                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="Est. Min" Foreground="#FFCCCCCC" Margin="0,0,0,4"/>
                    <TextBox x:Name="EstimatedMinutesTextBox"
                             Text="{Binding EstimatedMinutes}"
                             Width="70"
                             Style="{StaticResource PopupTextBoxStyle}"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Status" Foreground="#FFCCCCCC" Margin="0,0,0,4"/>
                    <ComboBox x:Name="StatusComboBox"
                                Width="120"
                                Style="{StaticResource PopupComboBoxStyle}"
                                Foreground="White"
                                Background="#FF2E2E2E"
                                IsEditable="True"
                                IsReadOnly="True"
                                TextSearch.TextPath="."
                                />
                </StackPanel>
            </WrapPanel>

            <!-- Subtask label -->
            <TextBlock Grid.Row="3"
                       Text="Subtasks"
                       Foreground="#FFCCCCCC"
                       Margin="0,0,0,8"/>

            <!-- Subtasks -->
            <Grid Grid.Row="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ListBox x:Name="SubtasksListBox"
                         ItemsSource="{Binding Subtasks}"
                         Style="{StaticResource PopupListBoxStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FF2E2E2E"
                                    CornerRadius="8"
                                    Padding="8"
                                    Margin="0,0,0,6">
                                <DockPanel LastChildFill="True">
                                    <Button Content="✕"
                                            Width="24"
                                            Height="24"
                                            Margin="8,0,0,0"
                                            DockPanel.Dock="Right"
                                            Style="{StaticResource FlatIconButtonStyle}"
                                            Click="RemoveSubtaskButton_Click"/>

                                    <CheckBox IsChecked="{Binding IsCompleted}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,8,0"/>

                                    <TextBox Text="{Binding Title}"
                                             Background="#FF3A3A3A"
                                             Foreground="White"
                                             BorderBrush="#FF4A4A4A"
                                             BorderThickness="1"
                                             Padding="6"
                                             VerticalAlignment="Center"/>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <WrapPanel Grid.Row="1" Margin="0,10,0,0">
                    <TextBox x:Name="NewSubtaskTextBox"
                             Width="250"
                             Style="{StaticResource PopupTextBoxStyle}"
                             Margin="0,0,8,0"/>
                    <Button Content="Add Subtask"
                            Style="{StaticResource PopupButtonStyle}"
                            Click="AddSubtaskButton_Click"/>
                </WrapPanel>
            </Grid>

            <!-- Footer -->
            <WrapPanel Grid.Row="5" HorizontalAlignment="Right" Margin="0,14,0,0">
                <Button Content="Cancel"
                        Width="90"
                        Style="{StaticResource DangerButtonStyle}"
                        Click="CancelButton_Click"/>
                <Button Content="Save"
                        Width="90"
                        Style="{StaticResource PopupButtonStyle}"
                        Click="SaveButton_Click"/>
            </WrapPanel>
        </Grid>
    </Border>
</Window>