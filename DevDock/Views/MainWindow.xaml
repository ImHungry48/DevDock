<Window x:Class="DevDock.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DevDock"
        Width="460"
        Height="700"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="#FF1E1E1E"
        AllowsTransparency="True"
        Icon="/Assets/tray.ico">

    <Window.Resources>
        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="8,10"/>
            <Setter Property="Background" Value="#FF2E2E2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF3E3E3E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Background" Value="#FF3A4A63"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="TaskCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF333333"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Width" Value="160"/>
        </Style>

        <DataTemplate x:Key="TaskCardTemplate">
            <Border Style="{StaticResource TaskCardStyle}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding Title}"
                               Foreground="White"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,0,8,0"/>

                        <Button Grid.Column="1"
                            Content="⋯"
                            Width="28"
                            Height="28"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="TaskMenuButton_Click"
                            Tag="{Binding DataContext.TaskBoard, RelativeSource={RelativeSource AncestorType=Window}}">
                            <Button.ContextMenu>
                                <ContextMenu Background="#FF2A2A2A"
                                             Foreground="White"
                                             BorderBrush="#FF3A3A3A"
                                             BorderThickness="1">
                                    <ContextMenu.Resources>
                                        <Style TargetType="MenuItem">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Background" Value="#FF2A2A2A"/>
                                            <Setter Property="Padding" Value="12,8"/>
                                        </Style>
                                    </ContextMenu.Resources>

                                    <MenuItem Header="Edit" Click="EditTaskMenuItem_Click"/>
                                    <MenuItem Header="Move Backward" Click="MoveTaskBackwardMenuItem_Click"/>
                                    <MenuItem Header="Move Forward" Click="MoveTaskForwardMenuItem_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Delete" Click="DeleteTaskMenuItem_Click"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </Grid>

                    <TextBlock Margin="0,6,0,0"
                           Foreground="#FFCCCCCC"
                           Text="{Binding DueDate, StringFormat=Due: {0:MMM d}}"/>

                    <TextBlock Foreground="#FFCCCCCC"
                           Margin="0,2,0,0"
                           Text="{Binding Priority, StringFormat=Priority: {0}}"/>

                    <TextBlock Foreground="#FFCCCCCC"
                           Text="{Binding EstimatedMinutes, StringFormat=Est: {0} min}"/>

                    <TextBlock Margin="0,4,0,0"
                           Foreground="#FFB8D8FF"
                           Text="{Binding SubtaskProgressText}"/>

                    <ItemsControl ItemsSource="{Binding Subtasks}" Margin="0,6,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Title}"
                                      IsChecked="{Binding IsCompleted, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Foreground="#FFD8D8D8"
                                      FontSize="11"
                                      Margin="0,2,0,0"
                                      Click="SubtaskCheckBox_Click"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>


    <Border Background="#FF1E1E1E" CornerRadius="18" BorderBrush="#FF3A3A3A" BorderThickness="1" Padding="0,10,0,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <!-- Reminder banner -->
            <Border Grid.Row="0"
                    Margin="12,12,12,8"
                    Padding="10"
                    Background="#FF2D3B55"
                    CornerRadius="10">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsReminderVisible}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <DockPanel>
                    <TextBlock Text="{Binding DeadlineReminder}"
                               Foreground="White"
                               FontSize="13"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Width="360"/>
                    <Button Content="X"
                            Command="{Binding DismissReminderCommand}"
                            Width="28"
                            Height="28"
                            Margin="8,0,0,0"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"/>
                </DockPanel>
            </Border>

            <!-- Header -->
            <Grid Grid.Row="1" Margin="16,0,16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="DevDock"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Content="✕"
                        Width="32"
                        Height="32"
                        Command="{Binding CloseWindowCommand}"
                        Background="Transparent"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"/>
            </Grid>

            <!-- Top nav -->
            <UniformGrid Grid.Row="2" Columns="5" Margin="12,0,12,10">
                <Button Content="Tasks" Command="{Binding SelectTasksCommand}" Style="{StaticResource TabButtonStyle}"/>
                <Button Content="Timer" Command="{Binding SelectTimerCommand}" Style="{StaticResource TabButtonStyle}"/>
                <Button Content="Snippets" Command="{Binding SelectSnippetsCommand}" Style="{StaticResource TabButtonStyle}"/>
                <Button Content="Notes" Command="{Binding SelectNotesCommand}" Style="{StaticResource TabButtonStyle}"/>
                <Button Content="Music" Command="{Binding SelectMusicCommand}" Style="{StaticResource TabButtonStyle}"/>
            </UniformGrid>

            <!-- Content -->
            <Border Grid.Row="3"
                    Margin="12,0,12,12"
                    Background="#FF252525"
                    CornerRadius="14"
                    Padding="12">
                <Grid>
                    <!-- Tasks -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTab}" Value="Tasks">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBlock Text="Daily Project Task List"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>

                            <!-- Task Form -->
                            <Border Background="#FF2E2E2E"
                                    CornerRadius="12"
                                    Padding="12"
                                    Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Add Task"
                                               Foreground="White"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,10"/>

                                    <TextBox Margin="0,0,0,8"
                                             Padding="8"
                                             Background="#FF3A3A3A"
                                             Foreground="White"
                                             BorderBrush="#FF4A4A4A"
                                             Text="{Binding TaskBoard.NewTaskTitle, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBox Margin="0,0,0,8"
                                             Padding="8"
                                             Background="#FF3A3A3A"
                                             Foreground="White"
                                             BorderBrush="#FF4A4A4A"
                                             Text="{Binding TaskBoard.NewTaskDescription, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Text="Subtasks (one per line)"
                                               Foreground="#FFCCCCCC"
                                               Margin="0,4,0,4"/>

                                    <TextBox Margin="0,0,0,8"
                                             Padding="8"
                                             Height="70"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             Background="#FF3A3A3A"
                                             Foreground="White"
                                             BorderBrush="#FF4A4A4A"
                                             Text="{Binding TaskBoard.NewTaskSubtasksText, UpdateSourceTrigger=PropertyChanged}" />

                                    <WrapPanel Margin="0,0,0,8">
                                        <DatePicker Width="130"
                                                Margin="0,0,8,0"
                                                SelectedDate="{Binding TaskBoard.NewTaskDueDate}" />

                                        <ComboBox Width="110"
                                                Margin="0,0,8,0"
                                                ItemsSource="{Binding TaskBoard.PriorityOptions}"
                                                SelectedItem="{Binding TaskBoard.NewTaskPriority}" />

                                        <TextBox Width="90"
                                                Margin="0,0,8,0"
                                                Padding="6"
                                                Background="#FF3A3A3A"
                                                Foreground="White"
                                                BorderBrush="#FF4A4A4A"
                                                Text="{Binding TaskBoard.NewTaskEstimatedMinutes, UpdateSourceTrigger=PropertyChanged}" />

                                        <ComboBox Width="130"
                                                ItemsSource="{Binding TaskBoard.StatusOptions}"
                                                SelectedItem="{Binding TaskBoard.NewTaskStatus}" />
                                    </WrapPanel>

                                    <Button Content="Add Task"
                                            Width="100"
                                            Command="{Binding TaskBoard.AddTaskCommand}"
                                            Style="{StaticResource ActionButtonStyle}" />
                                </StackPanel>
                            </Border>

                            <!-- Backlog Lane -->
                            <TextBlock Text="Backlog"
                               Foreground="#FFBDBDBD"
                               FontSize="14"
                               Margin="0,8,0,6"/>

                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="No tasks in Backlog"
                                           Foreground="#FF7F8C9A"
                                           FontStyle="Italic"
                                           Margin="8,4,0,4">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TaskBoard.BacklogTasks.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled">
                                    <ScrollViewer.Style>
                                        <Style TargetType="ScrollViewer">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TaskBoard.BacklogTasks.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ScrollViewer.Style>

                                    <ItemsControl ItemsSource="{Binding TaskBoard.BacklogTasks}"
                                                  ItemTemplate="{StaticResource TaskCardTemplate}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>

                            <!-- To-Do Lane -->
                            <TextBlock Text="To-Do" Foreground="#FFBDBDBD" FontSize="14" Margin="0,12,0,6"/>

                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="No tasks in To-Do"
                                           Foreground="#FF7F8C9A"
                                           FontStyle="Italic"
                                           Margin="8,4,0,4">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TaskBoard.TodoTasks.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled">
                                    <ScrollViewer.Style>
                                        <Style TargetType="ScrollViewer">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TaskBoard.TodoTasks.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ScrollViewer.Style>

                                    <ItemsControl ItemsSource="{Binding TaskBoard.TodoTasks}"
                                                  ItemTemplate="{StaticResource TaskCardTemplate}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>

                            <!-- In-Progress Lane -->
                            <TextBlock Text="In Progress" Foreground="#FFBDBDBD" FontSize="14" Margin="0,12,0,6"/>

                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="No tasks in In Progress"
                                           Foreground="#FF7F8C9A"
                                           FontStyle="Italic"
                                           Margin="8,4,0,4">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TaskBoard.InProgressTasks.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled">
                                    <ScrollViewer.Style>
                                        <Style TargetType="ScrollViewer">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TaskBoard.InProgressTasks.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ScrollViewer.Style>

                                    <ItemsControl ItemsSource="{Binding TaskBoard.InProgressTasks}"
                                                  ItemTemplate="{StaticResource TaskCardTemplate}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>

                            <!-- Code Review Lane -->
                            <TextBlock Text="Code Review" Foreground="#FFBDBDBD" FontSize="14" Margin="0,12,0,6"/>

                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="No tasks in Code Review"
                                           Foreground="#FF7F8C9A"
                                           FontStyle="Italic"
                                           Margin="8,4,0,4">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TaskBoard.CodeReviewTasks.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled">
                                    <ScrollViewer.Style>
                                        <Style TargetType="ScrollViewer">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TaskBoard.CodeReviewTasks.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ScrollViewer.Style>

                                    <ItemsControl ItemsSource="{Binding TaskBoard.CodeReviewTasks}"
                                                  ItemTemplate="{StaticResource TaskCardTemplate}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>

                            <!-- Completed Lane -->
                            <TextBlock Text="Completed" Foreground="#FFBDBDBD" FontSize="14" Margin="0,12,0,6"/>

                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="No tasks in Completed"
                                           Foreground="#FF7F8C9A"
                                           FontStyle="Italic"
                                           Margin="8,4,0,4">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TaskBoard.CompletedTasks.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Disabled">
                                    <ScrollViewer.Style>
                                        <Style TargetType="ScrollViewer">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TaskBoard.CompletedTasks.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ScrollViewer.Style>

                                    <ItemsControl ItemsSource="{Binding TaskBoard.CompletedTasks}"
                      ItemTemplate="{StaticResource TaskCardTemplate}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                            
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Timer -->
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTab}" Value="Timer">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Pomodoro.CurrentModeLabel}"
                   Foreground="White"
                   FontSize="20"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"/>

                            <TextBlock Text="{Binding Pomodoro.DisplayTime}"
                   Foreground="White"
                   FontSize="48"
                   Margin="0,16,0,16"
                   HorizontalAlignment="Center"/>

                            <WrapPanel HorizontalAlignment="Center">
                                <Button Content="Focus"
                    Command="{Binding Pomodoro.SetFocusCommand}"
                    Style="{StaticResource ActionButtonStyle}"/>

                                <Button Content="Short Break"
                    Command="{Binding Pomodoro.SetShortBreakCommand}"
                    Style="{StaticResource ActionButtonStyle}"/>

                                <Button Content="Long Break"
                    Command="{Binding Pomodoro.SetLongBreakCommand}"
                    Style="{StaticResource ActionButtonStyle}"/>
                            </WrapPanel>

                            <WrapPanel HorizontalAlignment="Center" Margin="0,10,0,0">
                                <Button Content="Start"
                    Command="{Binding Pomodoro.StartCommand}"
                    Style="{StaticResource ActionButtonStyle}"/>

                                <Button Content="Pause"
                    Command="{Binding Pomodoro.PauseCommand}"
                    Style="{StaticResource ActionButtonStyle}"/>

                                <Button Content="Reset"
                    Command="{Binding Pomodoro.ResetCommand}"
                    Style="{StaticResource ActionButtonStyle}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Snippets -->
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTab}" Value="Snippets">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Grid Margin="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBox Height="34"
                                     Margin="0,0,0,10"
                                     Padding="10,6,10,6"
                                     Background="#FF333333"
                                     Foreground="White"
                                     BorderBrush="#FF444444"
                                     Text="{Binding Snippets.SearchText, UpdateSourceTrigger=PropertyChanged}" />

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <ListBox Grid.Column="0"
                                         Background="#FF2E2E2E"
                                         Foreground="White"
                                         BorderThickness="0"
                                         ItemsSource="{Binding Snippets.FilteredSnippets}"
                                         SelectedItem="{Binding Snippets.SelectedSnippet}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Title}" Margin="8,6"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Grid Grid.Column="1" Margin="10,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBox Grid.Row="0"
                                             Height="34"
                                             Margin="0,0,0,10"
                                             Padding="10,6,10,6"
                                             Background="#FF333333"
                                             Foreground="White"
                                             BorderBrush="#FF444444"
                                             Text="{Binding Snippets.SelectedSnippetTitle, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBox Grid.Row="1"
                                             Padding="10"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             Background="#FF2E2E2E"
                                             Foreground="White"
                                             BorderThickness="0"
                                             Text="{Binding Snippets.SelectedSnippetContent, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>
                            </Grid>

                            <StackPanel Grid.Row="2"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,10,0,0">
                                                    <Button Content="Add Snippet"
                                        Width="110"
                                        Margin="0,0,10,0"
                                        Command="{Binding Snippets.AddSnippetCommand}"/>

                                                    <Button Content="Delete Snippet"
                                        Width="110"
                                        Command="{Binding Snippets.DeleteSnippetCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <!-- Notes -->
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTab}" Value="Notes">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <TextBox AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="#FF2E2E2E"
                                 Foreground="White"
                                 BorderThickness="0"
                                 FontSize="14"
                                 Padding="12,8,8,8"
                                 Text="{Binding NotesText, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <!-- Music -->
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTab}" Value="Music">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                            <TextBlock Text="Music Player"
                                       Foreground="White"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>

                            <Border Width="180"
                                    Height="180"
                                    Margin="0,16,0,12"
                                    CornerRadius="12"
                                    Background="#FF2A2A2A">
                                <Image Source="{Binding MusicPlayer.CurrentAlbumArtPath}"
                   Stretch="UniformToFill"/>
                            </Border>

                            <TextBlock Text="{Binding MusicPlayer.CurrentTrackTitle}"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Margin="0,4,0,2"/>

                            <TextBlock Text="{Binding MusicPlayer.CurrentTrackArtist}"
                                       Foreground="#FFCCCCCC"
                                       FontSize="13"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Margin="0,0,0,14"/>

                            <WrapPanel HorizontalAlignment="Center">
                                <Button Content="⏮"
                                        Command="{Binding MusicPlayer.PreviousCommand}"
                                        Style="{StaticResource ActionButtonStyle}"/>

                                <Button Content="{Binding MusicPlayer.PlayPauseLabel}"
                                        Command="{Binding MusicPlayer.PlayPauseCommand}"
                                        Style="{StaticResource ActionButtonStyle}"/>

                                <Button Content="⏭"
                                        Command="{Binding MusicPlayer.NextCommand}"
                                        Style="{StaticResource ActionButtonStyle}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Quote ticker -->
            <Border Grid.Row="4" Background="#FF151515" CornerRadius="0,0,18,18">
                <Grid ClipToBounds="True">
                    <TextBlock x:Name="QuoteTickerText"
                               Text="{Binding QuoteText}"
                               Foreground="#FFE0E0E0"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>